{
  "name": "task-calendar-sidebar",
  "version": "1.0.1",
  "description": "タスク管理＋Googleカレンダー連携サイドバーアプリ",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "gas:push": "bash ./gas/deploy-gas.sh",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win"
  },
  "dependencies": {
    "dotenv": "^16.3.1",
    "electron-store": "^8.1.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3",
    "jest": "^29.7.0",
    "@testing-library/jest-dom": "^6.1.4"
  },
  "build": {
    "appId": "com.ryuiyamada.yotei-tsuika",
    "productName": "予定追加ツール",
    "artifactName": "yotei-tsuika-${version}-${arch}.${ext}",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "main/**/*",
      "preload.js",
      "renderer.js",
      "index.html",
      "styles.css",
      "app-config.json",
      "gas-config.json.example",
      "assets/**/*",
      "renderer/**/*",
      "!node_modules/.cache",
      "!**/.DS_Store",
      "!**/Thumbs.db"
    ],
    "icon": "build/icon.png",
    "mac": {
      "target": ["dmg", "zip"],
      "category": "public.app-category.productivity",
      "icon": "build/icon.png"
    },
    "win": {
      "target": ["nsis", "portable"],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "artifactName": "yotei-tsuika-Setup-${version}.${ext}"
    }
  }
}
